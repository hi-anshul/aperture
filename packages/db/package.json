{
  "name": "@aperture/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "dotenv -e ../../.env -- prisma generate && tsc",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": { "@prisma/client": "^5.18.0", "bcryptjs": "^2.4.3" },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.18.0",
    "typescript": "^5.5.4",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.0"
  }
}
