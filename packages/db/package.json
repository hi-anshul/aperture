{
  "name": "@aperture/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "dotenv -e ../../.env -- prisma generate && tsc --noEmit",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": { "@prisma/client": "^5.18.0" },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.18.0",
    "typescript": "^5.5.4",
    "@types/node": "^20.16.5"
  }
}
